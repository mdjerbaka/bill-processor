# ─────────────────────────────────────────────────────────
# Bill Processor – Environment Variables
# The installer generates this file automatically.
# Security keys are auto-generated. Most settings (email,
# QuickBooks, OCR) are configured in the web UI after login.
# ─────────────────────────────────────────────────────────

# ── Database (local PostgreSQL — no changes needed) ──────
DATABASE_URL=postgresql+asyncpg://billproc:billproc_dev@db:5432/billprocessor
POSTGRES_USER=billproc
POSTGRES_PASSWORD=billproc_dev
POSTGRES_DB=billprocessor

# ── Security (auto-generated by installer) ───────────────
SECRET_KEY=REPLACE_ME
ENCRYPTION_KEY=REPLACE_ME

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App URL (do not change for local install) ────────────
APP_URL=http://localhost:3000

# ── OCR Provider ─────────────────────────────────────────
# Options: none, openai, azure, aws
# API keys can also be configured in-app via Settings page
OCR_PROVIDER=openai

# OpenAI (if OCR_PROVIDER=openai)
OPENAI_API_KEY=

# Azure Document Intelligence (if OCR_PROVIDER=azure)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# AWS Textract (if OCR_PROVIDER=aws)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── QuickBooks Online ────────────────────────────────────
# DEVELOPER: Fill these in before shipping to the client.
# The client does NOT need a developer account — they just
# click "Connect to QuickBooks" in the app and sign in with
# their regular QuickBooks account.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8000/api/v1/quickbooks/callback
QBO_ENVIRONMENT=production

# ── Microsoft 365 (Graph API for email) ──────────────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8000/api/v1/microsoft/callback

# ── Debug (optional, set to true for SQL logging) ────────
# DEBUG=false
